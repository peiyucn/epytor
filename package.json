{
  "name": "epytor-vscode",
  "displayName": "EPYTOR",
  "description": "WYSIWYG Markdown editor",
  "version": "1.1.0",
  "publisher": "peiyucn",
  "engines": {
    "vscode": "^1.93.0"
  },
  "packageManager": "pnpm@10.6.1",
  "extensionKind": [
    "ui"
  ],
  "icon": "images/icon.png",
  "categories": [
    "Formatters",
    "Other"
  ],
  "keywords": [
    "markdown",
    "wysiwyg",
    "editor",
    "table",
    "milkdown"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/peiyucn/epytor.git"
  },
  "bugs": {
    "url": "https://github.com/peiyucn/epytor/issues"
  },
  "homepage": "https://github.com/peiyucn/epytor#readme",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "customEditors": [
      {
        "viewType": "epytor.editor",
        "displayName": "EPYTOR",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "epytor.switchToTextEditor",
        "title": "%command.switchToTextEditor.title%",
        "icon": "$(eye-closed)"
      },
      {
        "command": "epytor.switchToPreview",
        "title": "%command.switchToPreview.title%",
        "icon": "$(eye)"
      },
      {
        "command": "epytor.debugModeEnable",
        "title": "%command.debugModeEnable.title%"
      },
      {
        "command": "epytor.debugModeDisable",
        "title": "%command.debugModeDisable.title%"
      }
    ],
    "keybindings": [
      {
        "command": "epytor.switchToTextEditor",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "activeCustomEditorId == 'epytor.editor'"
      },
      {
        "command": "epytor.switchToPreview",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "resourceExtname == '.md' && activeCustomEditorId != 'epytor.editor'"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "epytor.switchToTextEditor",
          "group": "navigation",
          "when": "activeCustomEditorId == 'epytor.editor'"
        },
        {
          "command": "epytor.switchToPreview",
          "group": "navigation",
          "when": "resourceExtname == '.md' && activeCustomEditorId != 'epytor.editor'"
        },
        {
          "command": "epytor.debugModeEnable",
          "group": "9_debug",
          "when": "activeCustomEditorId == 'epytor.editor' && !epytor.debugModeActive"
        },
        {
          "command": "epytor.debugModeDisable",
          "group": "9_debug",
          "when": "activeCustomEditorId == 'epytor.editor' && epytor.debugModeActive"
        }
      ]
    },
    "configuration": {
      "title": "epytor",
      "properties": {
        "epytor.autoSave": {
          "type": "boolean",
          "default": true,
          "description": "%config.autoSave.description%"
        },
        "epytor.autoSaveDelay": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "maximum": 10000,
          "description": "%config.autoSaveDelay.description%"
        },
        "epytor.codeBlockMaxHeight": {
          "type": "number",
          "default": 600,
          "minimum": 100,
          "description": "%config.codeBlockMaxHeight.description%"
        },
        "epytor.defaultMode": {
          "type": "string",
          "enum": [
            "wysiwyg",
            "source"
          ],
          "enumDescriptions": [
            "%config.defaultMode.wysiwyg%",
            "%config.defaultMode.source%"
          ],
          "default": "wysiwyg",
          "description": "%config.defaultMode.description%"
        },
        "epytor.editorMaxWidth": {
          "type": "number",
          "default": 900,
          "minimum": 400,
          "description": "%config.editorMaxWidth.description%"
        },
        "epytor.fontFamily": {
          "type": "string",
          "default": "",
          "description": "%config.fontFamily.description%"
        },
        "epytor.debugMode": {
          "type": "boolean",
          "default": false,
          "description": "%config.debugMode.description%"
        },
        "epytor.imageStorage": {
          "order": 10,
          "type": "string",
          "enum": [
            "local",
            "server"
          ],
          "enumDescriptions": [
            "%config.imageStorage.local%",
            "%config.imageStorage.server%"
          ],
          "default": "local",
          "description": "%config.imageStorage.description%"
        },
        "epytor.imageLocalPath": {
          "order": 11,
          "type": "string",
          "default": "",
          "description": "%config.imageLocalPath.description%"
        },
        "epytor.imageServerUrl": {
          "order": 12,
          "type": "string",
          "default": "",
          "description": "%config.imageServerUrl.description%"
        },
        "epytor.imageServerFieldName": {
          "order": 13,
          "type": "string",
          "default": "file",
          "description": "%config.imageServerFieldName.description%"
        },
        "epytor.imageServerExtraParams": {
          "order": 14,
          "type": "string",
          "default": "",
          "description": "%config.imageServerExtraParams.description%"
        },
        "epytor.imageServerResponsePath": {
          "order": 15,
          "type": "string",
          "default": "url",
          "description": "%config.imageServerResponsePath.description%"
        },
        "epytor.imageSelectionColor": {
          "order": 16,
          "type": "string",
          "default": "rgba(52, 211, 153, 0.6)",
          "description": "%config.imageSelectionColor.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.mjs --production",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package --no-dependencies --out releases/ --baseContentUrl https://github.com/peiyucn/epytor/blob/main --baseImagesUrl https://github.com/peiyucn/epytor/raw/main",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.0",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@vscode/vsce": "^2.32.0",
    "esbuild": "^0.24.0",
    "jsdom": "24.1.3",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@milkdown/crepe": "7.21.2",
    "@milkdown/kit": "7.21.2",
    "mermaid": "^11.15.0",
    "prosemirror-commands": "^1.7.1"
  }
}
